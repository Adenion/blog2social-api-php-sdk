{
  "name": "adenion/blog2social-api-php-sdk",
  "description": "Official PHP SDK for the Blog2Social API.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "adenion",
    "blog2social",
    "api",
    "sdk",
    "social-media"
  ],
  "homepage": "https://www.blog2social.com/",
  "support": {
    "issues": "https://github.com/adenion/blog2social-api-php-sdk/issues",
    "source": "https://github.com/adenion/blog2social-api-php-sdk"
  },
  "require": {
    "php": ">=8.1",
    "ext-curl": "*",
    "ext-json": "*"
  },
  "autoload": {
    "psr-4": {
      "Adenion\\Blog2Social\\Sdk\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Adenion\\Blog2Social\\Sdk\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0 || ^11.0"
  },
  "scripts": {
    "test": "phpunit",
    "lint": "find src examples tests -name '*.php' -print0 | xargs -0 -n1 php -l"
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "repository": {
    "type": "vcs",
    "url": "https://github.com/adenion/blog2social-api-php-sdk.git"
  }
}
